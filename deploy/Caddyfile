{
	admin off
	servers {
		protocols h1 h2 h3
	}
}

{$APP_HOSTNAME} {
	encode zstd gzip
	header {
		-Server
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
	}

	handle /api/auth/* {
		request_body {
			max_size 3MB
		}
		reverse_proxy auth-edge:3006
	}
	handle /.well-known/oauth-authorization-server {
		reverse_proxy auth-edge:3006
	}
	handle /.well-known/openid-configuration {
		reverse_proxy auth-edge:3006
	}
	handle /.well-known/oauth-protected-resource* {
		reverse_proxy private-mcp:3003
	}
	handle /mcp {
		request_body {
			max_size 3MB
		}
		reverse_proxy private-mcp:3003
	}
	handle /api/mcp/assets/*/content {
		request_body {
			max_size 5GB
		}
		reverse_proxy private-mcp:3003
	}

	handle /api/dashboard/assets/*/content {
		request_body {
			max_size 5GB
		}
		reverse_proxy app:3000
	}
	handle /api/dashboard/* {
		request_body {
			max_size 3MB
		}
		reverse_proxy app:3000
	}
	handle /api/health {
		reverse_proxy app:3000
	}
	handle /app* {
		reverse_proxy app:3000
	}
	handle /assets/* {
		reverse_proxy app:3000
	}

	handle /p/* {
		reverse_proxy public-web:3005
	}
	handle /public.css {
		reverse_proxy public-web:3005
	}
	handle /content.css {
		reverse_proxy public-web:3005
	}
	handle {
		request_body {
			max_size 64KB
		}
		reverse_proxy public-web:3005
	}
}

{$PUBLIC_MCP_HOSTNAME} {
	header {
		-Server
		-Set-Cookie
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}
	handle /mcp {
		request_body {
			max_size 128KB
		}
		reverse_proxy public-mcp:3001
	}
	handle {
		respond "Not found" 404
	}
}

{$ASSET_HOSTNAME} {
	request_body {
		max_size 64KB
	}
	header {
		-Server
		-Set-Cookie
		Access-Control-Allow-Origin "https://{$APP_HOSTNAME}"
		Cross-Origin-Resource-Policy cross-origin
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
	}
	handle /p/* {
		reverse_proxy public-web:3005
	}
	handle {
		respond "Not found" 404
	}
}
